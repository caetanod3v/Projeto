generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  coordenador
  secretaria
  admin
}

enum Repeticao {
  nenhuma
  semanal
  mensal
  diaria
}

enum StatusCompromisso {
  pendente
  aprovado
  recusado
}

enum StatusUsuario {
  pendente
  ativo
  bloqueado
}

model Usuario {
  id         Int           @id @default(autoincrement())
  nome       String
  email      String        @unique
  senha      String
  role       Role
  status     StatusUsuario @default(pendente)
  avatar_url String?
  created_at DateTime      @default(now())

  curso_id Int?
  curso    Curso? @relation(fields: [curso_id], references: [id])

  reset_token         String?
  reset_token_expires DateTime?

  google_access_token       String?
  google_refresh_token      String?
  google_token_expiry       DateTime?
  google_calendar_connected Boolean   @default(false)

  compromissos_criados     Compromisso[]  @relation("CriadorCompromisso")
  compromissos_aprovados   Compromisso[]  @relation("AprovadorCompromisso")
  compromissos_responsavel Compromisso[]  @relation("CoordenadorResponsavel")
  notificacoes             Notificacao[]
  logs                     LogAuditoria[]
  logs_acoes               LogAcao[]

  @@index([role, status])
  @@index([curso_id])
  @@index([created_at])

  @@map("usuarios")
}

model Notificacao {
  id              Int      @id @default(autoincrement())
  usuario_id      Int
  usuario         Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  titulo          String
  mensagem        String
  tipo            String
  lida            Boolean  @default(false)
  created_at      DateTime @default(now())
  referencia_id   Int?
  referencia_tipo String?

  @@index([usuario_id, created_at])
  @@index([usuario_id, lida])

  @@index([lida])
  @@index([created_at])
  @@index([referencia_tipo, referencia_id])


  @@map("notificacoes")
}

model LogAuditoria {
  id         Int      @id @default(autoincrement())
  usuario_id Int?
  usuario    Usuario? @relation(fields: [usuario_id], references: [id])
  acao       String
  detalhes   String?
  created_at DateTime @default(now())

  @@map("logs_auditoria")
}

model LogAcao {
  id          Int      @id @default(autoincrement())
  usuario_id  Int?
  usuario     Usuario? @relation(fields: [usuario_id], references: [id], onDelete: SetNull)
  acao        String
  entidade    String
  entidade_id Int?
  detalhes    Json?
  created_at  DateTime @default(now())

  @@index([usuario_id, created_at])
  @@index([entidade, entidade_id])
  @@index([acao, created_at])
  @@map("logs_acoes")
}

model Curso {
  id           Int           @id @default(autoincrement())
  nome         String
  created_at   DateTime      @default(now())
  compromissos Compromisso[]
  usuarios     Usuario[]

  @@index([created_at])

  @@map("cursos")
}

model Categoria {
  id           Int           @id @default(autoincrement())
  nome         String
  cor_hex      String
  created_at   DateTime      @default(now())
  compromissos Compromisso[]

  @@index([created_at])

  @@map("categorias")
}

model Compromisso {
  id                Int               @id @default(autoincrement())
  titulo            String
  descricao         String?
  dt_inicio         DateTime
  dt_fim            DateTime
  repeticao         Repeticao         @default(nenhuma)
  status            StatusCompromisso @default(pendente)
  motivo_recusa     String?
  mensagem_resposta String?
  aprovado_em       DateTime?
  respondido_em     DateTime?
  created_at        DateTime          @default(now())
  google_event_id   String?

  curso_id Int?
  curso    Curso? @relation(fields: [curso_id], references: [id])

  categoria_id Int?
  categoria    Categoria? @relation(fields: [categoria_id], references: [id])

  usuario_id Int?
  usuario    Usuario? @relation("CriadorCompromisso", fields: [usuario_id], references: [id])

  coordenador_id Int?
  coordenador    Usuario? @relation("CoordenadorResponsavel", fields: [coordenador_id], references: [id])

  aprovado_por Int?
  aprovador    Usuario? @relation("AprovadorCompromisso", fields: [aprovado_por], references: [id])

  @@index([usuario_id])
  @@index([coordenador_id])
  @@index([curso_id])
  @@index([categoria_id])
  @@index([status])
  @@index([created_at])
  @@index([dt_inicio])
  @@index([dt_fim])
  @@index([coordenador_id, status, dt_inicio])
  @@index([usuario_id, status, dt_inicio])
  @@index([curso_id, status, dt_inicio])
  @@map("compromissos")
}
